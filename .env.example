# Required: your company's Hesi/Ekuaibao OpenAPI credentials.
EKUAIBAO_APP_KEY=your_company_app_key
EKUAIBAO_APP_SECURITY=your_company_app_security

# Optional: use sandbox, test, or private deployment domain when needed.
# Default in expense_api.cjs: https://app.ekuaibao.com
EKUAIBAO_BASE_URL=https://app.ekuaibao.com
